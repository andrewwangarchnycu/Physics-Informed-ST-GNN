# --- System & Compiled Files ---
*.pyc
*.pid
*.log

# --- Executables & Scripts ---
*.sh
*.bat
*.ps1
*.ghpy
# gh_component/*.ghpy are plain-text Rhino 8 Script Component source (Python),
# not compiled binaries -- these are the actual product deliverable, track them.
!**/gh_component/*.ghpy

# --- Data & Large Files ---
*.csv
*.geojson
*.npz
*.pkl
*.h5
*.epw
*.png
*.svg
*.pdf
*.pbf
*.tif
*.tiff

# --- Configuration & Text ---
# WARNING: Usually, you want to track .py, .toml, .yaml, and .json. 
# Remove these from the list if they are your source code!




*.txt
!requirements.txt
!**/requirements.txt
*.pt
# --- GIS intermediate outputs (generated by nlsc_building_vectorize.py) ---
gis_data/building_mask.tif
gis_data/building_mask.tif.aux.xml
gis_data/building_mask_poly.*

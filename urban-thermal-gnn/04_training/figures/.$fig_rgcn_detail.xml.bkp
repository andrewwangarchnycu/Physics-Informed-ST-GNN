    <!-- ═══════════════════════════════════════════════════════════
         STACKING NOTE
    ═══════════════════════════════════════════════════════════ -->
    <mxCell id="stack_note"
      value="&lt;b&gt;RGCNEncoder = 3 × RGCNBlock&lt;/b&gt;&lt;br/&gt;
Layer 0: 128 → 128&lt;br/&gt;
Layer 1: 128 → 128&lt;br/&gt;
Layer 2: 128 → 128&lt;br/&gt;
Output: h_all (N&lt;sub&gt;obj&lt;/sub&gt;+N&lt;sub&gt;air&lt;/sub&gt;, 128)"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0FDF4;strokeColor=#16A34A;
             fontSize=9;arcSize=10;align=left;spacingLeft=10;verticalAlign=top;
             spacingTop=8;"
      vertex="1" parent="1">
      <mxGeometry x="870" y="620" width="260" height="130" as="geometry" />
    </mxCell>

    <!-- Per-step note -->
    <mxCell id="step_note"
      value="&lt;b&gt;Per-step Processing&lt;/b&gt;&lt;br/&gt;
For each t ∈ {0 … T-1}:&lt;br/&gt;
  1. air_encoder( air_feat[:,t,:] ) → h&lt;sub&gt;air,t&lt;/sub&gt;&lt;br/&gt;
  2. h_all = cat[h&lt;sub&gt;obj&lt;/sub&gt; ; h&lt;sub&gt;air,t&lt;/sub&gt;]&lt;br/&gt;
  3. edges_t = merge(dyn[t], static)&lt;br/&gt;
  4. h_all = RGCN(h_all, edges_t)&lt;br/&gt;
  5. air_hidden[t] = h_all[N&lt;sub&gt;obj&lt;/sub&gt;:]"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#B45309;
             fontSize=9;arcSize=10;align=left;spacingLeft=10;verticalAlign=top;
             spacingTop=8;"
      vertex="1" parent="1">
      <mxGeometry x="870" y="90" width="440" height="100" as="geometry" />
    </mxCell>


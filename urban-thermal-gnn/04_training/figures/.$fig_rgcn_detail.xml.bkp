    <!-- ═══════════════════════════════════════════════════════════
         FORMULA PANEL (right side)
    ═══════════════════════════════════════════════════════════ -->
    <mxCell id="formula"
      value="&lt;b&gt;RGCN Aggregation Formula  (Eq. 2)&lt;/b&gt;&lt;br/&gt;&lt;hr/&gt;
&lt;font face='Courier New' size='2'&gt;
h&lt;sub&gt;i&lt;/sub&gt;&lt;sup&gt;(l+1)&lt;/sup&gt; = σ
&lt;/font&gt;&lt;br/&gt;
&lt;font size='2'&gt;
&amp;nbsp;&amp;nbsp;&amp;nbsp; Σ&lt;sub&gt;r ∈ R&lt;/sub&gt; &amp;nbsp;
Σ&lt;sub&gt;j ∈ N&lt;sub&gt;r&lt;/sub&gt;(i)&lt;/sub&gt; &amp;nbsp;
( 1 / |N&lt;sub&gt;r&lt;/sub&gt;(i)| ) · W&lt;sub&gt;r&lt;/sub&gt; h&lt;sub&gt;j&lt;/sub&gt;&lt;sup&gt;(l)&lt;/sup&gt;
&amp;nbsp;+&amp;nbsp; W&lt;sub&gt;self&lt;/sub&gt; h&lt;sub&gt;i&lt;/sub&gt;&lt;sup&gt;(l)&lt;/sup&gt;
&lt;/font&gt;
&lt;br/&gt;&lt;br/&gt;
&lt;font size='2'&gt;&lt;b&gt;R = {&lt;/b&gt;
&lt;font color='#DC2626'&gt;shadow&lt;/font&gt;,
&lt;font color='#15803D'&gt;veg_et&lt;/font&gt;,
&lt;font color='#0891B2'&gt;convective&lt;/font&gt;,
&lt;font color='#9333EA'&gt;semantic&lt;/font&gt;,
&lt;font color='#EA580C'&gt;contiguity&lt;/font&gt;
&lt;b&gt;}&lt;/b&gt;&lt;/font&gt;
&lt;br/&gt;&lt;br/&gt;
&lt;hr/&gt;
&lt;b&gt;Residual + Normalisation:&lt;/b&gt;&lt;br/&gt;
&lt;font size='2'&gt;h&lt;sub&gt;i&lt;/sub&gt;&lt;sup&gt;(l+1)&lt;/sup&gt; ← LayerNorm( h&lt;sub&gt;i&lt;/sub&gt;&lt;sup&gt;(l+1)&lt;/sup&gt; + ResProj(h&lt;sub&gt;i&lt;/sub&gt;&lt;sup&gt;(l)&lt;/sup&gt;) )&lt;br/&gt;
followed by PReLU + Dropout&lt;/font&gt;
&lt;br/&gt;&lt;br/&gt;
&lt;hr/&gt;
&lt;b&gt;Implemented in:&lt;/b&gt;&lt;br/&gt;
&lt;font size='2' color='#475569'&gt;03_model/layers/rgcn_block.py → RGCNBlock.forward()&lt;br/&gt;
Stacked 3× by RGCNEncoder&lt;/font&gt;"
      style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAF9;strokeColor=#7C3AED;
             fontStyle=0;fontSize=10;arcSize=8;strokeWidth=2;align=left;
             verticalAlign=top;spacingLeft=14;spacingTop=12;spacingRight=10;"
      vertex="1" parent="1">
      <mxGeometry x="870" y="200" width="440" height="380" as="geometry" />
    </mxCell>

